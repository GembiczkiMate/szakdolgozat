  <library_effects>
    <effect id="Floor-effect">
      <profile_COMMON>
        <newparam sid="Floor_png-surface">
          <surface type="2D">
            <init_from>Floor_png</init_from>
          </surface>
        </newparam>
        <newparam sid="Floor_png-sampler">
          <sampler2D>
            <source>Floor_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="Floor_png-sampler" texcoord="WorkCell-mesh-map-0"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
